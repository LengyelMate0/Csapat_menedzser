<Window x:Class="Focicsapat_menedzser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Focicsapat_menedzser"
        mc:Ignorable="d"
        Title="Focicsapat Menedzser" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Csapat Keret Kezelő" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>

        <DataGrid x:Name="dgJatekosok" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Név" Binding="{Binding Nev}" Width="*"/>
                <DataGridTextColumn Header="Poszt" Binding="{Binding Poszt}" Width="150"/>
                <DataGridTextColumn Header="Gólok" Binding="{Binding Golok}" Width="80"/>
                <DataGridTextColumn Header="Passzok" Binding="{Binding Passzok}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Adatok Betöltése" Click="BtnBeolvas_Click" Width="130" Height="35" Margin="5"/>
            <Button Content="Mentés / Export" Click="BtnMentes_Click" Width="130" Height="35" Margin="5"/>
            <Button Content="Kijelölt törlése" Click="BtnTorles_Click" Width="130" Height="35" Margin="5" Background="#FFC0C0"/>
        </StackPanel>
    </Grid>
</Window>
